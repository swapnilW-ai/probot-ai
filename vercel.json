{
  "version": 2,

  "builds": [
    { "src": "api/webhook.js", "use": "@vercel/node" },
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "frontend/js/**/*.js", "use": "@vercel/static" },
    { "src": "frontend/styles/**/*.css", "use": "@vercel/static" }
  ],

  "routes": [
    { "src": "^/api/webhook$", "dest": "/api/webhook.js" },

    { "src": "^/$", "dest": "/index.html" },

    { "src": "^/portal$", "dest": "/frontend/pages/agent-portal.html" },
    { "src": "^/dashboard$", "dest": "/frontend/pages/agent-dashboard.html" },
    { "src": "^/properties$", "dest": "/frontend/pages/properties.html" },

    { "src": "^/frontend/(.*)", "dest": "/frontend/$1" }
  ]
}
