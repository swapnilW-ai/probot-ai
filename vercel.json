{
  "version": 2,
  "builds": [
    { "src": "api/webhook.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.js" },

    { "src": "/", "dest": "/index.html" },

    { "src": "/dashboard", "dest": "/agent-dashboard.html" },
    { "src": "/properties", "dest": "/properties.html" },

    { "src": "/(.*\\.html)", "dest": "/$1" }
  ]
}
